message_step("09. FinnGen EOAD + Bradley Age65 IVW meta-enhanced MAGMA analysis")

if (!file.exists(FINNGEN_EOAD_SUMSTATS)) stop("FinnGen EOAD summary statistics not found: ", FINNGEN_EOAD_SUMSTATS)
if (!file.exists(BRADLEY_AGE65_INPUT)) stop("Bradley Age65 input not found. Run script 07 first or set BRADLEY_AGE65_MAGMA_INPUT.")

finngen <- standardise_for_meta(FINNGEN_EOAD_SUMSTATS, "FinnGen_EOAD")
bradley65 <- standardise_for_meta(BRADLEY_AGE65_INPUT, "Bradley_NHW_Age65")
harm <- harmonize_for_meta(finngen, bradley65)
meta <- ivw_meta(harm)

harm_qc <- data.table(
  n_finngen_variants = nrow(finngen),
  n_bradley_age65_variants = nrow(bradley65),
  n_harmonized_variants = nrow(harm),
  n_meta_variants = nrow(meta),
  same_direction_fraction = mean(meta$SAME_DIRECTION, na.rm = TRUE),
  n_apoe_region = sum(meta$APOE_REGION, na.rm = TRUE)
)
fwrite(harm_qc, file.path(TAB_DIR, "Table_09_meta_harmonization_QC.tsv"), sep = "\t")

meta_file <- file.path(TAB_DIR, "FinnGen_Bradley_Age65_IVW_meta_full_summary_statistics.tsv")
fwrite(meta, meta_file, sep = "\t", quote = FALSE, na = "NA")
fwrite(meta[seq_len(min(nrow(meta), 1000))], file.path(TAB_DIR, "Table_09_top1000_meta_SNPs.tsv"), sep = "\t")

prs_weights <- meta[, .(SNP, CHR, BP, A1, A2, BETA, SE, P)]
fwrite(prs_weights, file.path(PRS_DIR, "FinnGen_Bradley_Age65_IVW_meta_PRS_weights.tsv"), sep = "\t", quote = FALSE, na = "NA")

meta_qc <- data.table(
  n_meta_variants = nrow(meta),
  min_p = min(meta$P, na.rm = TRUE),
  n_p_lt_5e_8 = sum(meta$P < 5e-8, na.rm = TRUE),
  n_p_lt_1e_5 = sum(meta$P < 1e-5, na.rm = TRUE),
  median_i2 = median(meta$I2, na.rm = TRUE),
  n_het_p_lt_005 = sum(meta$HET_P < 0.05, na.rm = TRUE),
  meta_summary_file = meta_file
)
fwrite(meta_qc, file.path(TAB_DIR, "Table_09_meta_summary_QC.tsv"), sep = "\t")

# ------------------------------------------------------------------------------
# 4. MAGMA input and MAGMA analysis
# ------------------------------------------------------------------------------

magma_input <- meta[, .(
  SNP, CHR, BP, A1, A2, BETA, SE, P,
  N = ifelse(is.na(N_FINNGEN), 0, N_FINNGEN) + ifelse(is.na(N_BRADLEY), 0, N_BRADLEY)
)]
magma_input <- magma_input[!duplicated(SNP)]
magma_input_file <- file.path(INPUT_DIR, paste0(META_TAG, "_MAGMA_input.tsv"))
fwrite(magma_input, magma_input_file, sep = "\t", quote = FALSE, na = "NA")

magma_input_qc <- data.table(
  n_input_snps = nrow(magma_input),
  min_p = min(magma_input$P, na.rm = TRUE),
  n_p_lt_5e_8 = sum(magma_input$P < 5e-8, na.rm = TRUE),
  n_p_lt_1e_5 = sum(magma_input$P < 1e-5, na.rm = TRUE),
  input_file = magma_input_file
)
fwrite(magma_input_qc, file.path(TAB_DIR, "Table_09_MAGMA_input_QC.tsv"), sep = "\t")

magma_outputs <- run_magma_for_meta(magma_input_file)
fwrite(magma_outputs, file.path(TAB_DIR, "Table_09_MAGMA_output_files.tsv"), sep = "\t")

# ------------------------------------------------------------------------------
# 5. Summarize MAGMA and candidate pathway support
# ------------------------------------------------------------------------------

current_eoad_genes <- read_magma_genes(CURRENT_EOAD_GENES, "FinnGen_EOAD")
current_load_genes <- read_magma_genes(CURRENT_LOAD_GENES, "LOAD")
bradley65_genes <- read_magma_genes(BRADLEY_AGE65_GENES, "Bradley_NHW_Age65")
meta_genes <- read_magma_genes(magma_outputs$genes_out[1], "Meta_FinnGen_Bradley_Age65")

gene_overview <- rbindlist(lapply(list(current_eoad_genes, bradley65_genes, meta_genes, current_load_genes), function(x) {
  data.table(
    dataset = x$dataset[1],
    n_genes = nrow(x),
    n_fdr_005 = sum(x$FDR < 0.05, na.rm = TRUE),
    n_bonferroni_005 = sum(x$P < 0.05 / nrow(x), na.rm = TRUE),
    min_p = min(x$P, na.rm = TRUE)
  )
}), fill = TRUE)
fwrite(gene_overview, file.path(TAB_DIR, "Table_09_MAGMA_gene_level_overview.tsv"), sep = "\t")

current_eoad_gsa <- read_magma_gsa(CURRENT_EOAD_GSA, "FinnGen_EOAD")
bradley65_gsa <- read_magma_gsa(BRADLEY_AGE65_GSA, "Bradley_NHW_Age65")
meta_gsa <- read_magma_gsa(magma_outputs$gsa_out[1], "Meta_FinnGen_Bradley_Age65")
current_load_gsa <- read_magma_gsa(CURRENT_LOAD_GSA, "LOAD")
gsa_summary <- gsa_overview(current_eoad_gsa, bradley65_gsa, meta_gsa, current_load_gsa)
if (nrow(gsa_summary) > 0) fwrite(gsa_summary, file.path(TAB_DIR, "Table_09_MAGMA_gene_set_overview.tsv"), sep = "\t")

candidate_sets <- read_candidate_gene_sets(CANDIDATE_GENESET_FILE)
candidate_results <- rbindlist(list(
  candidate_rank_test(current_eoad_genes, candidate_sets, "FinnGen_EOAD", "APOE_included"),
  candidate_rank_test(current_eoad_genes, candidate_sets, "FinnGen_EOAD", "APOE_excluded"),
  candidate_rank_test(bradley65_genes, candidate_sets, "Bradley_NHW_Age65", "APOE_included"),
  candidate_rank_test(bradley65_genes, candidate_sets, "Bradley_NHW_Age65", "APOE_excluded"),
  candidate_rank_test(meta_genes, candidate_sets, "Meta_FinnGen_Bradley_Age65", "APOE_included"),
  candidate_rank_test(meta_genes, candidate_sets, "Meta_FinnGen_Bradley_Age65", "APOE_excluded"),
  candidate_rank_test(current_load_genes, candidate_sets, "LOAD", "APOE_included"),
  candidate_rank_test(current_load_genes, candidate_sets, "LOAD", "APOE_excluded")
), fill = TRUE)
if (nrow(candidate_results) > 0) {
  fwrite(candidate_results, file.path(TAB_DIR, "Table_09_candidate_pathway_gene_set_support_by_MAGMA_rank.tsv"), sep = "\t")
  candidate_wide <- dcast(
    candidate_results[status == "tested"],
    set_name + analysis ~ dataset,
    value.var = c("mean_z", "wilcox_p", "wilcox_fdr")
  )
  fwrite(candidate_wide, file.path(TAB_DIR, "Table_09_candidate_pathway_gene_set_support_wide.tsv"), sep = "\t")
}

