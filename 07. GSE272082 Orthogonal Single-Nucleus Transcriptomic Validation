message_step <- function(...) {
  message("\n", paste0(...))
}

`%||%` <- function(x, y) {
  if (is.null(x)) y else x
}

get_assay_layer <- function(object, layer_name = "data") {
  f <- get("GetAssayData")
  if ("layer" %in% names(formals(f))) {
    GetAssayData(object, assay = "RNA", layer = layer_name)
  } else {
    GetAssayData(object, assay = "RNA", slot = layer_name)
  }
}

has_assay_layer <- function(object, layer_name = "data") {
  out <- tryCatch({
    mat <- get_assay_layer(object, layer_name)
    nrow(mat) > 0 && ncol(mat) > 0
  }, error = function(e) FALSE)
  isTRUE(out)
}

read_h5_counts <- function(path) {
  x <- Seurat::Read10X_h5(path, use.names = TRUE, unique.features = TRUE)
  if (is.list(x)) {
    if ("Gene Expression" %in% names(x)) return(x[["Gene Expression"]])
    if ("RNA" %in% names(x)) return(x[["RNA"]])
    return(x[[1]])
  }
  x
}

