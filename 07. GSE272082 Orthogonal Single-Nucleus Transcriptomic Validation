make_file_metadata <- function(h5_files) {
  file_meta <- tibble(
    file_path = h5_files,
    file_name = basename(h5_files),
    gsm = stringr::str_extract(file_name, "^GSM[0-9]+"),
    sample_id = stringr::str_match(
      file_name,
      "^GSM[0-9]+_([^_]+)_filtered_feature_bc_matrix\\.h5$"
    )[, 2]
  )
  file_meta %>%
    left_join(sample_metadata_default(), by = "sample_id") %>%
    arrange(sample_id)
}

load_or_create_metadata <- function(h5_files, metadata_file) {
  template <- make_file_metadata(h5_files)
  if (!file.exists(metadata_file)) {
    dir.create(dirname(metadata_file), showWarnings = FALSE, recursive = TRUE)
    readr::write_csv(template, metadata_file)
    missing_labels <- template %>% filter(is.na(diagnosis) | is.na(region))
    if (nrow(missing_labels) > 0) {
      stop(
        "Metadata template was created but some samples need manual labels: ",
        metadata_file
      )
    }
    return(template)
  }

  user_meta <- readr::read_csv(metadata_file, show_col_types = FALSE)
  required <- c("file_name", "sample_id", "diagnosis", "region", "donor_id")
  missing <- setdiff(required, colnames(user_meta))
  if (length(missing) > 0) {
    user_meta <- template %>%
      select(file_path, file_name, gsm, sample_id) %>%
      left_join(user_meta, by = "sample_id")
  }

  out <- template %>%
    select(file_path, file_name, gsm, sample_id) %>%
    left_join(
      user_meta %>%
        select(any_of(c("sample_id", "diagnosis", "region", "donor_id", "sex", "age_on_death", "pmi_hours"))),
      by = "sample_id",
      suffix = c("", ".user")
    )

  required2 <- c("file_path", "file_name", "sample_id", "diagnosis", "region", "donor_id")
  missing2 <- setdiff(required2, colnames(out))
  if (length(missing2) > 0) stop("Metadata is missing columns: ", paste(missing2, collapse = ", "))

  out %>%
    mutate(
      region = toupper(region),
      diagnosis = factor(diagnosis, levels = c("control", "sEOAD")),
      donor_id = ifelse(is.na(donor_id) | donor_id == "", sample_id, donor_id)
    )
}

build_seurat_from_h5 <- function(h5_dir, metadata_file) {
  h5_files <- list.files(
    h5_dir,
    pattern = "_filtered_feature_bc_matrix\\.h5$",
    recursive = TRUE,
    full.names = TRUE
  )
  if (length(h5_files) == 0) {
    stop("No filtered feature-barcode h5 files found in: ", h5_dir)
  }

  sample_meta <- load_or_create_metadata(h5_files, metadata_file)
  readr::write_tsv(sample_meta, file.path(TAB_DIR, "gse272082_sample_metadata_used.tsv"))

  obj_list <- vector("list", nrow(sample_meta))
  for (i in seq_len(nrow(sample_meta))) {
    row <- sample_meta[i, ]
    message("Reading ", row$sample_id, ": ", row$file_name)
    counts <- read_h5_counts(row$file_path)
    obj <- CreateSeuratObject(counts = counts, project = row$sample_id, min.cells = 3, min.features = 200)
    obj$sample_id <- row$sample_id
    obj$diagnosis <- row$diagnosis
    obj$region <- row$region
    obj$donor_id <- row$donor_id
    obj$sex <- row$sex %||% NA_character_
    obj$age_on_death <- row$age_on_death %||% NA_real_
    obj$pmi_hours <- row$pmi_hours %||% NA_real_
    obj_list[[i]] <- obj
  }

  names(obj_list) <- sample_meta$sample_id
  seu <- merge(obj_list[[1]], y = obj_list[-1], add.cell.ids = names(obj_list), project = "GSE272082_sEOAD")

  seu[["percent.mt"]] <- PercentageFeatureSet(seu, pattern = "^MT-")
  seu <- subset(seu, subset = nFeature_RNA >= 200 & nFeature_RNA <= 8000 & percent.mt <= 20)
  seu <- NormalizeData(seu, normalization.method = "LogNormalize", scale.factor = 10000)
  seu <- FindVariableFeatures(seu, selection.method = "vst", nfeatures = 3000)
  seu <- ScaleData(seu, features = VariableFeatures(seu), verbose = FALSE)
  seu <- RunPCA(seu, features = VariableFeatures(seu), npcs = 30, verbose = FALSE)
  seu <- FindNeighbors(seu, dims = 1:30, verbose = FALSE)
  seu <- FindClusters(seu, resolution = 0.5, verbose = FALSE)
  seu <- RunUMAP(seu, dims = 1:30, verbose = FALSE)
  seu
}

ensure_preprocessed <- function(seu) {
  DefaultAssay(seu) <- "RNA"
  if (!has_assay_layer(seu, "data")) {
    seu <- NormalizeData(seu, normalization.method = "LogNormalize", scale.factor = 10000)
  }
  if (length(VariableFeatures(seu)) == 0) {
    seu <- FindVariableFeatures(seu, selection.method = "vst", nfeatures = 3000)
  }
  if (!"pca" %in% names(seu@reductions)) {
    seu <- ScaleData(seu, features = VariableFeatures(seu), verbose = FALSE)
    seu <- RunPCA(seu, features = VariableFeatures(seu), npcs = 30, verbose = FALSE)
  }
  if (!"umap" %in% names(seu@reductions)) {
    seu <- FindNeighbors(seu, dims = 1:30, verbose = FALSE)
    seu <- FindClusters(seu, resolution = 0.5, verbose = FALSE)
    seu <- RunUMAP(seu, dims = 1:30, verbose = FALSE)
  }
  seu
}

compute_marker_signals <- function(object, gene_sets, prefix) {
  data_mat <- get_assay_layer(object, "data")
  rn <- rownames(data_mat)
  rn_upper <- toupper(rn)

  signal_meta <- list()
  overlap_meta <- list()

  for (set_name in names(gene_sets)) {
    genes <- unique(toupper(gene_sets[[set_name]]))
    idx <- match(genes, rn_upper)
    matched <- rn[idx[!is.na(idx)]]
    out_col <- paste0(prefix, make.names(set_name))

    if (length(matched) >= 2) {
      signal_meta[[out_col]] <- Matrix::colMeans(data_mat[matched, , drop = FALSE])
    } else {
      signal_meta[[out_col]] <- rep(NA_real_, ncol(data_mat))
    }

    overlap_meta[[set_name]] <- tibble(
      set_name = set_name,
      n_input = length(unique(gene_sets[[set_name]])),
      n_matched = length(matched),
      matched_genes = paste(matched, collapse = ";")
    )
  }

  signal_df <- as.data.frame(signal_meta)
  rownames(signal_df) <- colnames(data_mat)
  object <- AddMetaData(object, metadata = signal_df)
  list(object = object, overlap = bind_rows(overlap_meta))
}

aggregate_pseudobulk <- function(seu, celltype_col) {
  counts <- get_assay_layer(seu, "counts")
  meta <- seu@meta.data %>%
    rownames_to_column("cell") %>%
    mutate(
      cell_type = as.character(.data[[celltype_col]]),
      diagnosis = as.character(diagnosis),
      region = as.character(region),
      sample_id = as.character(sample_id)
    ) %>%
    filter(!is.na(cell_type), cell_type != "Uncertain", diagnosis %in% c("control", "sEOAD"))

  meta <- meta %>%
    group_by(region, diagnosis, sample_id, donor_id, cell_type) %>%
    mutate(n_cells_group = n()) %>%
    ungroup() %>%
    filter(n_cells_group >= MIN_CELLS_PER_SAMPLE_CELLTYPE)

  if (nrow(meta) == 0) stop("No cells passed pseudobulk grouping filters.")

  counts <- counts[, meta$cell, drop = FALSE]
  meta$pb_id <- paste(meta$region, meta$cell_type, meta$sample_id, sep = "__")

  design <- Matrix::sparse.model.matrix(~ 0 + pb_id, data = meta)
  colnames(design) <- sub("^pb_id", "", colnames(design))
  pb_counts <- counts %*% design

  pb_meta <- meta %>%
    distinct(pb_id, region, cell_type, sample_id, donor_id, diagnosis, sex, age_on_death, pmi_hours, n_cells_group) %>%
    arrange(region, cell_type, sample_id)

  pb_counts <- pb_counts[, pb_meta$pb_id, drop = FALSE]
  list(counts = pb_counts, meta = pb_meta)
}

run_edgeR_for_group <- function(pb_counts, pb_meta, region_value, cell_type_value) {
  idx <- which(pb_meta$region == region_value & pb_meta$cell_type == cell_type_value)
  sub_meta <- pb_meta[idx, , drop = FALSE]
  if (nrow(sub_meta) == 0) return(NULL)
  if (length(unique(sub_meta$diagnosis)) < 2) return(NULL)

  n_by_group <- table(sub_meta$diagnosis)
  if (any(n_by_group[c("control", "sEOAD")] < MIN_SAMPLES_PER_GROUP)) return(NULL)

  sub_counts <- pb_counts[, sub_meta$pb_id, drop = FALSE]
  group <- factor(sub_meta$diagnosis, levels = c("control", "sEOAD"))

  y <- edgeR::DGEList(counts = sub_counts, group = group)
  keep <- edgeR::filterByExpr(y, group = group)
  y <- y[keep, , keep.lib.sizes = FALSE]
  if (nrow(y) < 100) return(NULL)

  y <- edgeR::calcNormFactors(y)
  design <- model.matrix(~ group)
  fit <- edgeR::glmQLFit(y, design, robust = TRUE)
  qlf <- edgeR::glmQLFTest(fit, coef = "groupsEOAD")
  tt <- edgeR::topTags(qlf, n = Inf, sort.by = "none")$table

  tt %>%
    rownames_to_column("gene") %>%
    transmute(
      region = region_value,
      marker_cell_type = cell_type_value,
      gene = gene,
      logFC = logFC,
      logCPM = logCPM,
      F = F,
      p_value = PValue,
      fdr_gene = FDR
    )
}

test_candidate_gene_sets <- function(de_results, candidate_sets) {
  if (is.null(de_results) || nrow(de_results) == 0) return(tibble())
  all_tests <- list()
  de_split <- split(de_results, paste(de_results$region, de_results$marker_cell_type, sep = "__"))

  for (key in names(de_split)) {
    de <- de_split[[key]]
    region_value <- unique(de$region)
    cell_type_value <- unique(de$marker_cell_type)

    for (set_name in names(candidate_sets)) {
      genes <- unique(toupper(candidate_sets[[set_name]]))
      de$gene_upper <- toupper(de$gene)
      sub <- de %>% filter(gene_upper %in% genes)
      if (nrow(sub) < MIN_GENE_SET_OVERLAP) next

      wt <- tryCatch(
        stats::wilcox.test(sub$logFC, mu = 0, exact = FALSE),
        error = function(e) NULL
      )
      if (is.null(wt)) next

      all_tests[[length(all_tests) + 1]] <- tibble(
        region = region_value,
        marker_cell_type = cell_type_value,
        set_name = set_name,
        n_overlap = nrow(sub),
        mean_logFC = mean(sub$logFC, na.rm = TRUE),
        median_logFC = median(sub$logFC, na.rm = TRUE),
        p_value = wt$p.value,
        matched_genes = paste(sub$gene, collapse = ";")
      )
    }
  }

  bind_rows(all_tests) %>%
    mutate(
      fdr = p.adjust(p_value, method = "BH"),
      direction = ifelse(mean_logFC > 0, "Higher in sEOAD", "Lower in sEOAD")
    ) %>%
    arrange(fdr, p_value)
}

plot_significant_gene_sets <- function(sig_tests, out_prefix) {
  if (nrow(sig_tests) == 0) return(invisible(NULL))

  plot_df <- sig_tests %>%
    mutate(
      comparison = paste(region, marker_cell_type, sep = " | "),
      minus_log10_fdr = -log10(pmax(fdr, 1e-300)),
      set_name = factor(set_name, levels = unique(set_name)),
      comparison = forcats::fct_reorder(comparison, abs(mean_logFC), .fun = max)
    )

  p <- ggplot(plot_df, aes(x = set_name, y = comparison)) +
    geom_point(
      aes(size = minus_log10_fdr, colour = mean_logFC),
      alpha = 0.90
    ) +
    scale_colour_gradient2(
      low = "#2166AC", mid = "grey95", high = "#B2182B",
      midpoint = 0, name = "Mean logFC\nsEOAD-control"
    ) +
    scale_size_continuous(name = "-log10(FDR)", range = c(2.2, 8.5)) +
    labs(
      title = "GSE272082 sEOAD pseudobulk candidate pathway signals",
      subtitle = "Original-study marker framework; FDR-significant pathway-level tests only",
      x = "Candidate pathway gene set",
      y = "Brain region and reconstructed cell type"
    ) +
    theme_bw(base_size = 11) +
    theme(
      panel.grid.minor = element_blank(),
      axis.text.x = element_text(angle = 35, hjust = 1),
      legend.position = "right",
      plot.title = element_text(face = "bold")
    )

  ggsave(paste0(out_prefix, ".pdf"), p, width = 10.5, height = max(6, 0.32 * length(unique(plot_df$comparison)) + 2))
  ggsave(paste0(out_prefix, ".png"), p, width = 10.5, height = max(6, 0.32 * length(unique(plot_df$comparison)) + 2), dpi = 300)
}

