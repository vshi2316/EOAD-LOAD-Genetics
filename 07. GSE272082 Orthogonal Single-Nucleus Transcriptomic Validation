message_step("Step 1: Load or build Seurat object")

if (file.exists(INPUT_RDS)) {
  message("Reading existing Seurat object: ", INPUT_RDS)
  seu <- readRDS(INPUT_RDS)
} else {
  message("Existing Seurat object not found. Building from h5 files in: ", H5_DIR)
  seu <- build_seurat_from_h5(H5_DIR, METADATA_FILE)
}

seu <- ensure_preprocessed(seu)
DefaultAssay(seu) <- "RNA"
seu$diagnosis <- factor(seu$diagnosis, levels = c("control", "sEOAD"))
seu$region <- factor(toupper(as.character(seu$region)), levels = c("PFC", "EC", "HIP"))

readr::write_tsv(
  seu@meta.data %>%
    as.data.frame() %>%
    count(region, diagnosis, sample_id, name = "n_cells"),
  file.path(TAB_DIR, "cells_per_sample_after_qc.tsv")
)

message_step("Step 2: Reconstruct original-study-framework cell labels")

anno_signal <- compute_marker_signals(seu, original_markers, prefix = "ORIGCT__")
seu <- anno_signal$object
readr::write_tsv(anno_signal$overlap, file.path(TAB_DIR, "original_framework_marker_overlap.tsv"))

orig_cols <- grep("^ORIGCT__", colnames(seu@meta.data), value = TRUE)
orig_mat <- as.matrix(seu@meta.data[, orig_cols, drop = FALSE])
orig_names <- sub("^ORIGCT__", "", orig_cols)

best_idx <- max.col(orig_mat, ties.method = "first")
seu$orig_framework_cell_type <- orig_names[best_idx]
seu$orig_framework_best_signal <- apply(orig_mat, 1, max, na.rm = TRUE)
seu$orig_framework_second_signal <- apply(orig_mat, 1, function(x) sort(x, decreasing = TRUE)[2])
seu$orig_framework_signal_gap <- seu$orig_framework_best_signal - seu$orig_framework_second_signal
seu$orig_framework_confident <- (
  !is.na(seu$orig_framework_best_signal) &
    seu$orig_framework_best_signal >= BEST_MARKER_SIGNAL_CUT &
    seu$orig_framework_signal_gap >= MARKER_SIGNAL_GAP_CUT
)

seu$orig_framework_cell_type_conf <- ifelse(
  seu$orig_framework_confident,
  seu$orig_framework_cell_type,
  "Uncertain"
)

seu$orig_framework_cell_type_conf <- factor(
  seu$orig_framework_cell_type_conf,
  levels = c(
    "Astrocyte", "Excitatory", "Inhibitory", "Microglia",
    "Oligodendrocyte", "OPC", "Endothelial", "VLMC_Per", "Uncertain"
  )
)

readr::write_tsv(
  seu@meta.data %>%
    rownames_to_column("cell") %>%
    select(
      cell, sample_id, diagnosis, region, donor_id,
      orig_framework_cell_type, orig_framework_best_signal,
      orig_framework_second_signal, orig_framework_signal_gap,
      orig_framework_confident, orig_framework_cell_type_conf
    ),
  file.path(TAB_DIR, "cell_annotation_original_framework.tsv")
)

readr::write_tsv(
  seu@meta.data %>%
    count(region, diagnosis, sample_id, orig_framework_cell_type_conf, name = "n_cells"),
  file.path(TAB_DIR, "celltype_counts_original_framework.tsv")
)

if ("umap" %in% names(seu@reductions)) {
  p_umap <- DimPlot(
    seu,
    group.by = "orig_framework_cell_type_conf",
    reduction = "umap",
    label = TRUE,
    repel = TRUE,
    raster = TRUE
  ) +
    ggtitle("GSE272082 original-study-framework cell labels")
  ggsave(file.path(FIG_DIR, "Figure_GSE272082_original_framework_celltypes_umap.pdf"), p_umap, width = 10, height = 8)
}

message_step("Step 3: Aggregate pseudobulk counts")

pb <- aggregate_pseudobulk(seu, "orig_framework_cell_type_conf")
readr::write_tsv(pb$meta, file.path(TAB_DIR, "pseudobulk_sample_metadata.tsv"))

message_step("Step 4: Run pseudobulk differential expression")

regions <- sort(unique(pb$meta$region))
cell_types <- sort(unique(pb$meta$cell_type))

de_list <- list()
for (region_value in regions) {
  for (cell_type_value in cell_types) {
    message("DE: ", region_value, " / ", cell_type_value)
    res <- run_edgeR_for_group(pb$counts, pb$meta, region_value, cell_type_value)
    if (!is.null(res) && nrow(res) > 0) {
      de_list[[length(de_list) + 1]] <- res
    }
  }
}

de_results <- bind_rows(de_list)
if (nrow(de_results) == 0) stop("No pseudobulk DE results were generated.")

message_step("Step 5: Test candidate pathway gene sets")

gene_set_overlap <- tibble(
  set_name = names(candidate_sets),
  n_input = purrr::map_int(candidate_sets, ~ length(unique(.x))),
  n_matched = purrr::map_int(candidate_sets, function(x) {
    sum(toupper(unique(x)) %in% toupper(rownames(get_assay_layer(seu, "data"))))
  }),
  matched_genes = purrr::map_chr(candidate_sets, function(x) {
    genes <- rownames(get_assay_layer(seu, "data"))
    paste(genes[toupper(genes) %in% toupper(unique(x))], collapse = ";")
  })
)
readr::write_tsv(gene_set_overlap, file.path(TAB_DIR, "candidate_gene_set_overlap.tsv"))

gene_set_tests_all <- test_candidate_gene_sets(de_results, candidate_sets)
gene_set_tests_significant <- gene_set_tests_all %>%
  filter(fdr < FDR_CUT) %>%
  arrange(fdr, p_value)

readr::write_tsv(
  gene_set_tests_significant,
  file.path(TAB_DIR, "candidate_gene_set_tests_significant.tsv")
)

readr::write_tsv(
  gene_set_tests_significant %>%
    select(
      region, marker_cell_type, set_name, n_overlap,
      mean_logFC, median_logFC, p_value, fdr, direction
    ),
  file.path(TAB_DIR, "candidate_gene_set_tests_manuscript_focus.tsv")
)

message_step("Step 6: Plot significant pathway-level signals")

plot_significant_gene_sets(
  gene_set_tests_significant,
  file.path(FIG_DIR, "Figure_GSE272082_pseudobulk_gene_set_signals")
)

message_step("Step 7: Save processed object and analysis summary")

saveRDS(seu, file.path(RDS_DIR, "GSE272082_original_framework_annotated_seurat.rds"))

summary_lines <- c(
  "GSE272082 orthogonal single-nucleus transcriptomic validation",
  paste0("Generated: ", Sys.time()),
  "",
  "Interpretation:",
  "This analysis provides orthogonal transcriptomic contextualization, not independent EOAD genetic replication.",
  "",
  "Inputs:",
  paste0("- DATA_DIR: ", DATA_DIR),
  paste0("- INPUT_RDS: ", INPUT_RDS),
  paste0("- H5_DIR: ", H5_DIR),
  paste0("- METADATA_FILE: ", METADATA_FILE),
  "",
  "Key parameters:",
  paste0("- BEST_MARKER_SIGNAL_CUT: ", BEST_MARKER_SIGNAL_CUT),
  paste0("- MARKER_SIGNAL_GAP_CUT: ", MARKER_SIGNAL_GAP_CUT),
  paste0("- MIN_CELLS_PER_SAMPLE_CELLTYPE: ", MIN_CELLS_PER_SAMPLE_CELLTYPE),
  paste0("- MIN_SAMPLES_PER_GROUP: ", MIN_SAMPLES_PER_GROUP),
  paste0("- MIN_GENE_SET_OVERLAP: ", MIN_GENE_SET_OVERLAP),
  paste0("- FDR_CUT: ", FDR_CUT),
  "",
  "Main outputs:",
  "- tables/candidate_gene_set_tests_significant.tsv",
  "- tables/candidate_gene_set_tests_manuscript_focus.tsv",
  "- figures/Figure_GSE272082_pseudobulk_gene_set_signals.pdf",
  "- figures/Figure_GSE272082_pseudobulk_gene_set_signals.png",
  "",
  paste0("Number of FDR-significant candidate pathway tests: ", nrow(gene_set_tests_significant))
)

writeLines(summary_lines, con = file.path(OUT_DIR, "analysis_summary.txt"))

cat("\n==============================================================================\n")
cat("GSE272082 orthogonal transcriptomic validation completed.\n")
cat("Output directory:\n", OUT_DIR, "\n", sep = "")
cat("FDR-significant candidate pathway tests: ", nrow(gene_set_tests_significant), "\n", sep = "")
cat("==============================================================================\n")
